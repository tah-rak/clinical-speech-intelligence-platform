# Application
APP_NAME=Clinical Speech Intelligence Platform
APP_VERSION=1.0.0
DEBUG=false
API_PREFIX=/api
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:80

# Database
DATABASE_PROVIDER=local
DATABASE_URL=postgresql://csip:csip@db:5432/csip

# Storage
STORAGE_PROVIDER=local
UPLOAD_DIR=uploads

# AWS (optional)
AWS_ENABLED=false
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Speech-to-Text: local | azure | gcp
STT_PROVIDER=local
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Azure Speech (optional)
AZURE_SPEECH_ENABLED=false
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# GCP (optional)
GCP_ENABLED=false
GOOGLE_APPLICATION_CREDENTIALS=
FIRESTORE_PROJECT_ID=

# LLM — plug-and-play (see backend/app/services/llm/presets.py)
# Set LLM_ENABLED=true, pick a provider, add your API key.
LLM_ENABLED=false
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
LLM_API_STYLE=
LLM_TIMEOUT_SECONDS=90

# Examples (replace with your own keys — never commit real values):
# OpenAI:    LLM_PROVIDER=openai     LLM_API_KEY=your-openai-key
# Groq:      LLM_PROVIDER=groq       LLM_API_KEY=your-groq-key
# Anthropic: LLM_PROVIDER=anthropic  LLM_API_KEY=your-anthropic-key
# Ollama:    LLM_PROVIDER=ollama     (no key needed if running locally)
# Custom:    LLM_PROVIDER=custom     LLM_BASE_URL=https://your-api/v1  LLM_MODEL=your-model

# Legacy Ollama flags (still supported)
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2
